# Copy this file to .env and fill in real values. Never commit the real .env.

# NCBI E-utilities (optional for light use, but recommended -> raises rate limit from 3 to 10 req/sec)
NCBI_API_KEY=
NCBI_EMAIL=you@example.com

# YouTube Data API v3 (console.cloud.google.com -> enable "YouTube Data API v3" -> create API key)
YOUTUBE_API_KEY=

# openFDA (no key needed for light use; add one if you hit rate limits: open.fda.gov/apis/authentication)
OPENFDA_API_KEY=

# Relational staging DB (Postgres or MySQL - pick one and set the matching URL)
POSTGRES_URL=postgresql+psycopg2://user:password@localhost:5432/skincare_staging
MYSQL_URL=mysql+pymysql://user:password@localhost:3306/skincare_staging

# NoSQL store for raw Open Beauty Facts JSON
MONGO_URI=mongodb://localhost:27017
MONGO_DB=skincare_raw

# CosIng bulk export - EU CosIng has no stable public bulk API; export manually from
# https://ec.europa.eu/growth/tools-databases/cosing/ (Ingredients/Substances tab -> Export)
# and drop the CSV here:
COSING_CSV_PATH=raw/structured/cosing_export.csv
